# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.rs    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf

# Windows-specific files use CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binaries
*.ico       binary
*.icns      binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.svg       text eol=lf
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.mp3       binary
*.wav       binary
*.dmg       binary
*.exe       binary
*.dll       binary
*.dylib     binary
*.so        binary
*.deb       binary
*.rpm       binary
*.AppImage  binary
*.msi       binary
*.zip       binary
*.tar.gz    binary
